{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self' https://*.googleapis.com https://firestore.googleapis.com https://api.telegram.org https://*.firebase.com https://*.firebaseio.com;" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/index",
      "destination": "/index.html"
    },
    {
      "source": "/catalogo",
      "destination": "/catalogo.html"
    },
    {
      "source": "/order",
      "destination": "/order.html"
    },
    {
      "source": "/confirmed",
      "destination": "/confirmed.html"
    },
    {
      "source": "/factura",
      "destination": "/factura.html"
    },
    {
      "source": "/puntos",
      "destination": "/puntos.html"
    },
    {
      "source": "/terminos",
      "destination": "/terminos.html"
    },
    {
      "source": "/loyalty",
      "destination": "/loyalty.html"
    },
    {
      "source": "/wallet",
      "destination": "/wallet.html"
    },
    {
      "source": "/preorder",
      "destination": "/preorder.html"
    },
    {
      "source": "/verify",
      "destination": "/verify.html"
    },
    {
      "source": "/s/:code",
      "destination": "/api/s?code=:code"
    },
    {
      "source": "/track",
      "destination": "/track.html"
    },
    {
      "source": "/mi-cuenta",
      "destination": "/mi-cuenta.html"
    },
    {
      "source": "/onboarding",
      "destination": "/onboarding.html"
    },
    {
      "source": "/admin-v2",
      "destination": "/admin-v2.html"
    },
    {
      "source": "/pos-v2",
      "destination": "/pos-v2.html"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "happy-corner.vercel.app"
        }
      ],
      "destination": "https://happycorner.lol/:path*",
      "permanent": true
    },
    {
      "source": "/dashboard",
      "destination": "/mi-cuenta",
      "permanent": true
    },
    {
      "source": "/dashboard.html",
      "destination": "/mi-cuenta",
      "permanent": true
    },
    {
      "source": "/admin",
      "destination": "/admin-v2",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/checkDebtReminders",
      "schedule": "0 8 * * *"
    }
  ]
}