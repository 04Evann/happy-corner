rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated and is their own doc
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Helper to check if user is authenticated and has admin role
    function isAdmin() {
      return request.auth != null && 
        (
          request.auth.token.role == 'admin' ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    // Users collection rules
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if request.auth != null && request.auth.uid == uid;
      
      // Updates: owner can update, but cannot touch activeDebt, happyPoints, or role,
      // and customerCode is immutable once set. Admin has full rights.
      allow update: if isAdmin() || (
        isOwner(uid) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['activeDebt', 'happyPoints', 'role']) &&
        (
          !('customerCode' in resource.data) ||
          request.resource.data.customerCode == resource.data.customerCode
        )
      );
    }

    // customerCodes collection (lookup to guarantee uniqueness)
    match /customerCodes/{code} {
      allow read: if request.auth != null || isAdmin();
      // Allow creation during onboarding if it maps to user's UID and is not already taken
      allow create: if request.auth != null && 
                    request.resource.data.uid == request.auth.uid &&
                    resource == null;
      allow update, delete: if false; // Immutable
    }

    // orders collection rules
    match /orders/{orderId} {
      // Allow get publicly (order ID known) but restrict listing/querying to owner or admin
      allow get: if true;
      allow list: if isAdmin() || (request.auth != null && resource.data.customerUID == request.auth.uid);
      // Allow creation by logged-in user
      allow create: if request.auth != null && (request.resource.data.customerUID == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // movements collection rules (server-only write, client-read-only)
    match /movements/{movementId} {
      allow read, get, list: if isAdmin() || (request.auth != null && resource.data.customerUID == request.auth.uid);
      allow write: if isAdmin(); // Admin can adjust or write movements
    }

    // debtContracts collection rules (server-only write, client-read-only)
    match /debtContracts/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // creditScores collection rules (server-only write, client-read own)
    match /creditScores/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin(); // Only server (Admin SDK) may set scores
    }

    // verificationPins collection (server-only write, no client reads)
    match /verificationPins/{uid} {
      allow read: if false; // Never expose PIN hashes to client
      allow write: if isAdmin();
    }
  }
}
